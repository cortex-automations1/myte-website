# Google Analytics 4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Resend — contact form email delivery
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where contact form submissions are delivered
CONTACT_NOTIFICATION_EMAIL=info@mytetech.com

# From address used by Resend. Must be on a verified domain.
# Typical value: "MYTE Website <noreply@mytetech.com>"
CONTACT_FROM_EMAIL="MYTE Website <noreply@mytetech.com>"
